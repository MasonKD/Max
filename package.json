{
  "name": "max-openclaw-selfmax-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "smoke:login": "node scripts/selfmax-smoke.mjs login",
    "smoke:probe": "node scripts/selfmax-smoke.mjs probe",
    "smoke:public": "npm run build --silent && node scripts/public-api-smoke.mjs",
    "smoke:sequence": "node scripts/selfmax-smoke.mjs sequence",
    "smoke:keep-open": "node scripts/selfmax-smoke.mjs keep-open",
    "smoke:signin": "node scripts/selfmax-smoke.mjs signin-diagnostic"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.52.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}

PORT=8080
SELFMAX_BASE_URL=https://selfmax.ai
SELFMAX_EMAIL=you@example.com
SELFMAX_PASSWORD=changeme
SELFMAX_STATE_KEY=openclaw_state
SELFMAX_STORAGE_STATE_PATH=.auth/selfmax-storage-state.json
SELFMAX_AUTH_MIN_ARCHIVED=0
HEADLESS=true
LOGIN_EMAIL_SELECTOR=input[type="email"]
LOGIN_PASSWORD_SELECTOR=input[type="password"]
LOGIN_SUBMIT_SELECTOR=button[type="submit"]
COACH_INPUT_SELECTOR=textarea
COACH_SEND_SELECTOR=button[type="submit"]
COACH_MESSAGE_SELECTOR=[data-role="coach-message"]
LOG_LEVEL=info
LOG_PRETTY=false
LOG_TIMINGS=true
